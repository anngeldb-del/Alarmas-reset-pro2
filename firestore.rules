rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Colecciones antiguas (previas al login) — quedan completamente cerradas.
    match /ordenes/{document=**} {
      allow read, write: if false;
    }
    match /checklist_services/{document=**} {
      allow read, write: if false;
    }
    match /checklist_custom_items/{document=**} {
      allow read, write: if false;
    }
    match /export_logs/{document=**} {
      allow read, write: if false;
    }
    // Sin inicio de sesión: todos los dispositivos comparten la misma ruta
    // (usuarios/compartido/...), abierta a cualquiera que conozca el proyecto.
    // Decisión explícita para evitar bloqueos de login (ver README).
    match /usuarios/{document=**} {
      allow read, write: if true;
    }
  }
}
