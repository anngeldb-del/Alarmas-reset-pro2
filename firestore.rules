rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Colecciones antiguas (previas al login) — solo lectura autenticada,
    // únicamente para que migrar.html pueda copiarlas a usuarios/{uid}.
    // Ninguna escritura nueva debe llegar aquí.
    match /ordenes/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /checklist_services/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /checklist_custom_items/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /export_logs/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Datos privados por usuario — solo el propietario autenticado
    // (ordenes, checklist_services, checklist_custom_items, export_logs, finanzas, clientes, citas, ...)
    match /usuarios/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
